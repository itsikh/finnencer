# ── Build outputs ─────────────────────────────────────────────
build/
.gradle/
.kotlin/
out/
gen/
bin/

# Compiled artefacts
*.apk
*.aab
*.aar
*.ap_
*.dex
*.class

# ── Local config (never share) ─────────────────────────────────
local.properties
keystore.properties
*.jks
*.keystore

# ── IDE / OS noise ────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
*.bak
*.orig
.DS_Store
Thumbs.db
desktop.ini

# ── Logs / profiling ──────────────────────────────────────────
*.log
*.hprof
hs_err_pid*.log

# ── Android Studio capture / lint / nav editor ────────────────
captures/
.navigation/
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# ── Native build (unused here, but template-safe) ─────────────
.externalNativeBuild/
.cxx/

# ── Test / report output ──────────────────────────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# ── 3rd-party SDK files we don't ship ─────────────────────────
google-services.json

# ── In-app artifacts (must stay out of code repo) ─────────────
#   The bug reporter writes screenshots to a dedicated orphan
#   branch ("bug-screenshots") via the GitHub Contents API — they
#   should never land on `main`. This dir is the local staging
#   path we never want tracked.
screenshots/
.autofix-logs/

# ── Misc tooling drop boxes ───────────────────────────────────
*.tmp
*.cache
